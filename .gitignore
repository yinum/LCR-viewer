# Vendored libraries — re-download, see README
plotly-basic.min.js
jszip.min.js

# Input spectra and generated viewers (data / outputs — never commit)
*.txt
*.csv
*.xy
*.html

# Generated viewers + sibling CSVs land here (output/LCR/<dataset>/) — never commit
/output/

# Single-file uploader build artifact (git-ignored alongside /output/)
/dist/

# Python
__pycache__/
*.pyc

# OS
.DS_Store

# local tuned preset written by the viewer's Save preset button
preset.json

# Test pages (allow the labeler test page; *.html is otherwise ignored)
!tests/*.html

# Bundled sample spectrum for uploader's "Try example" button — committed
# code-side asset (not user data); shipped inside dist/LCR_viewer.html.
!example_spectrum.xy
